  "exclusions": [
    {
      "pattern": "python/xy/static/**",
      "rationale": "Generated JavaScript bundles are governed by the separate Node semantic coverage gate and bundle-freshness check."
    },
    {
      "pattern": "tests/**",
      "rationale": "Test implementation is evidence, while this ratchet governs shipped Python package behavior."
    },
    {
      "pattern": "python/reflex-xy/tests/**",
      "rationale": "Adapter tests drive the shipped reflex_xy package but are not themselves production code."
    },
    {
      "pattern": "scripts/**",
      "rationale": "Repository automation has dedicated verifier and mutation gates rather than the shipped-package baseline."
    },
    {
      "pattern": "benchmarks/**",
      "rationale": "Benchmark harnesses are governed by their schema and methodology gates, not production-package coverage."
    },
    {
      "pattern": "examples/**",
      "rationale": "Examples are exercised by example and browser checks but are not distributed as the core Python package."
    }
  ]
}
